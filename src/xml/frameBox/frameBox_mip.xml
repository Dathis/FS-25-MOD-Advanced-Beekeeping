<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="multipleItemPurchase" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../shared/xml/schema/vehicle.xsd">
    <storeData>
        <name>$l10n_storeItem_frameBox</name>
        <functions>
            <function>$l10n_function_frameBox</function>
        </functions>
        <specs>
            <weight ignore="true"/>
        </specs>
        <image>src/xml/frameBox/store_frameBox.dds</image>
        <price>180</price>
        <allowLeasing>false</allowLeasing>
        <canBeSold>false</canBeSold>
        <rotation>0</rotation>
        <brand>SMALLBEEKEEPER</brand>
        <category>pallets beekeeping</category>
        <financeCategory>OTHER</financeCategory>
        <shopHeight>1.5</shopHeight>
        <storeIconRendering>
            <settings centerIcon="true" cameraXRot="-15" cameraYRot="35"/>
        </storeIconRendering>
    </storeData>

    <base>
        <typeDesc>$l10n_typeDesc_frameBox</typeDesc>
        <filename>$data/objects/multiPurchaseItem/multiPurchaseItem.i3d</filename>
        <size width="2.4" length="1.8" height="1.5"/>
        <components>
            <component centerOfMass="0 0.5 0" solverIterationCount="10" mass="150"/>
        </components>
    </base>

    <fillUnit>
        <fillUnitConfigurations>
            <fillUnitConfiguration>
                <fillUnits>
                    <fillUnit unitTextOverride="$l10n_unit_pieces" fillTypes="HONEY" capacity="1" ignoreFillLimit="true"/>
                </fillUnits>
            </fillUnitConfiguration>
        </fillUnitConfigurations>
    </fillUnit>

    <multipleItemPurchase filename="src/xml/frameBox/frameBox.xml" isVehicle="true">
        <offsets>
            <offset amount="1" offset="0 0 0"/>
            <offset amount="12" offset="0 0 0"/>
        </offsets>
        <itemPositions>
            <itemPosition position="-0.80 0.00 0.55" rotation="0 90 0"/>
            <itemPosition position="0.00 0.00 0.55" rotation="0 90 0"/>
            <itemPosition position="0.80 0.00 0.55" rotation="0 90 0"/>
            <itemPosition position="-0.80 0.00 0.00" rotation="0 90 0"/>
            <itemPosition position="0.00 0.00 0.00" rotation="0 90 0"/>
            <itemPosition position="0.80 0.00 0.00" rotation="0 90 0"/>
            <itemPosition position="-0.80 0.00 -0.55" rotation="0 90 0"/>
            <itemPosition position="0.00 0.00 -0.55" rotation="0 90 0"/>
            <itemPosition position="0.80 0.00 -0.55" rotation="0 90 0"/>
            <itemPosition position="-0.80 0.45 0.00" rotation="0 90 0"/>
            <itemPosition position="0.00 0.45 0.00" rotation="0 90 0"/>
            <itemPosition position="0.80 0.45 0.00" rotation="0 90 0"/>
        </itemPositions>
    </multipleItemPurchase>

    <multipleItemPurchaseAmountConfigurations>
        <multipleItemPurchaseAmountConfiguration name="1" price="0"/>
        <multipleItemPurchaseAmountConfiguration name="2" price="180"/>
        <multipleItemPurchaseAmountConfiguration name="3" price="360"/>
        <multipleItemPurchaseAmountConfiguration name="4" price="540"/>
        <multipleItemPurchaseAmountConfiguration name="5" price="720"/>
        <multipleItemPurchaseAmountConfiguration name="6" price="900"/>
        <multipleItemPurchaseAmountConfiguration name="7" price="1080"/>
        <multipleItemPurchaseAmountConfiguration name="8" price="1260"/>
        <multipleItemPurchaseAmountConfiguration name="9" price="1440"/>
        <multipleItemPurchaseAmountConfiguration name="10" price="1620"/>
        <multipleItemPurchaseAmountConfiguration name="11" price="1800"/>
        <multipleItemPurchaseAmountConfiguration name="12" price="1980"/>
    </multipleItemPurchaseAmountConfigurations>
</vehicle>
