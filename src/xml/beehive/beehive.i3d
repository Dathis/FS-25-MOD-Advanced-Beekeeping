<?xml version="1.0" encoding="iso-8859-1"?>

<i3D name="beehiveGeneric01" version="1.6" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://i3d.giants.ch/schema/i3d-1.6.xsd">

  <Files>
    <File fileId="1" filename="beehive_diffuse.dds" />
    <File fileId="2" filename="beehive_normal.dds" />
    <File fileId="3" filename="beehive_specular.dds" />
    <File fileId="4" filename="$data/shaders/placeableShader.xml" />
    <File fileId="5" filename="$data/shared/warningStripes_diffuse.png" />
    <File fileId="6" filename="$data/shared/warningStripes_normal.png" />
    <File fileId="7" filename="$data/shared/warningStripes_specular.png" />
