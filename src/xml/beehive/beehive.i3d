    <Material name="advancedBeekeepingInteractionArea_mat" materialId="3">
      <Texture fileId="5"/>
      <Normalmap fileId="6"/>
      <Glossmap fileId="7"/>
    </Material>
  </Materials>


  <Shapes externalShapesFile="beehive.i3d.shapes">
  </Shapes>

  <Scene>
    <TransformGroup name="beehiveGeneric01" lockedgroup="true" static="true" density="0" collisionFilterMask="0xfffffbff" nodeId="1">
      <TransformGroup name="clearAreas" nodeId="2">
        <TransformGroup name="clearAreaStart01" translation="-0.75 0 -0.75" nodeId="3">
          <TransformGroup name="clearAreaWidth01" translation="0 0 1.5" nodeId="4"/>
          <TransformGroup name="clearAreaHeight01" translation="1.5 0 0" nodeId="5"/>
        </TransformGroup>
      </TransformGroup>
      <TransformGroup name="levelAreas" nodeId="6">
        <TransformGroup name="levelAreaStart01" translation="-0.75 0 -0.75" nodeId="7">
          <TransformGroup name="levelAreaWidth01" translation="0 0 1.5" nodeId="8"/>
          <TransformGroup name="levelAreaHeight01" translation="1.5 0 0" nodeId="9"/>
        </TransformGroup>
      </TransformGroup>
      <TransformGroup name="indoorAreas" nodeId="10">
        <TransformGroup name="indoorAreaStart01" translation="-0.75 0 -0.75" nodeId="11">
          <TransformGroup name="indoorAreaWidth01" translation="0 0 1.5" nodeId="12"/>
          <TransformGroup name="indoorAreaHeight01" translation="1.5 0 0" nodeId="13"/>
        </TransformGroup>
      </TransformGroup>
      <TransformGroup name="testAreas" nodeId="14">
