        </TransformGroup>
      </TransformGroup>
      <TransformGroup name="visuals" nodeId="20">
        <TransformGroup name="visuals_lod" lockedgroup="true" lodDistance="0 50" static="true" density="0" collisionFilterMask="0xfffffbff" nodeId="21">
          <TransformGroup name="LOD0" nodeId="22">
            <Shape name="beehiveGeneric01_lod0" shapeId="1" castsShadows="true" receiveShadows="true" materialIds="1" clipDistance="300" nodeId="23"/>
          </TransformGroup>
          <TransformGroup name="LOD1" nodeId="24">
            <Shape name="beehiveGeneric01_lod1" shapeId="2" castsShadows="true" receiveShadows="true" materialIds="1" clipDistance="300" nodeId="25"/>
          </TransformGroup>
        </TransformGroup>
        <Shape name="emitterShape" translation="-0.052263 0.766316 0.591669" rotation="0 90 0" shapeId="3" castsShadows="true" receiveShadows="true" nonRenderable="true" materialIds="2" clipDistance="300" nodeId="26"/>
      </TransformGroup>
      <TransformGroup name="collisions" nodeId="27">
        <Shape name="collision" shapeId="4" static="true" density="0" collisionFilterGroup="0x3e" collisionFilterMask="0xfffffbff" castsShadows="true" receiveShadows="true" nonRenderable="true" materialIds="2" nodeId="28"/>
        <Shape name="tipCollision" shapeId="5" static="true" collisionFilterGroup="0x8" collisionFilterMask="0x1" castsShadows="true" receiveShadows="true" nonRenderable="true" materialIds="2" nodeId="29"/>
        <Shape name="infoTrigger" translation="0 0.4 0" scale="3 1.8 3" shapeId="4" static="true" trigger="true" density="0" collisionFilterGroup="0x20000000" collisionFilterMask="0x100000" castsShadows="false" receiveShadows="false" nonRenderable="true" materialIds="2" clipDistance="300" nodeId="30"/>
      </TransformGroup>
      <TransformGroup name="interactionNode" translation="0 0 -0.95" nodeId="31">
        <Shape name="interactionAreaVisual" translation="0 0.02 0" scale="1.35 0.02 1.35" shapeId="4" castsShadows="false" receiveShadows="true" materialIds="3" clipDistance="80" nodeId="35"/>
        <Shape name="interactionTrigger" translation="0 0.45 0" scale="1.45 1 1.45" shapeId="4" static="true" trigger="true" collisionFilterGroup="0x20000000" collisionFilterMask="0xffffffff" castsShadows="false" receiveShadows="false" nonRenderable="true" materialIds="2" nodeId="36"/>
