    <title>
        <en>Advanced Beekeeping</en>
        <ru>Advanced Beekeeping</ru>
    </title>

    <description>
        <en><![CDATA[Adds a deeper beekeeping workflow with portable bee colonies, wax frames, hives, and honey processing.]]></en>
        <ru><![CDATA[Добавляет более детальное пчеловодство: переносимые пчелиные семьи, восковые рамки, ульи и переработку меда.]]></ru>
    </description>

    <multiplayer supported="true"/>

    <brands>
        <brand name="SMALLBEEKEEPER" title="Small Beekeeper" image="src/brandLogo.dds"/>
    </brands>

    <storeCategories>
        <storeCategory type="OBJECT" name="beekeeping" title="Beekeeping" image="src/xml/beehive/store_beehive.dds" insertAfter="pallets"/>
    </storeCategories>

